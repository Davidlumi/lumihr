    "M": "rho*core + (1-rho)*( 0.30*Regulatory_Pressure + 0.20*Audit_Scrutiny + 0.15*sector_gov_tilt + 0.10*(Unionised/100) )",
    "C": "rho*core + (1-rho)*( 0.25*sector_pay_tilt + 0.20*Risk_Appetite + ownership_c_bump - 0.08*(Unionised/100) )",
    "notes": "all inputs 0..1; clamp to [0,1]; rho shared-core weight (~0.55 start); jitter(org,factor) added after"
  },
